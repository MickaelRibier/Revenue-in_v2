<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description"
    content="RevenueIn – Interim & Fractional Sales Leadership for startups and scale-ups. Build a scalable, high-performing sales machine." />
  <title>RevenueIn – Build a Scalable Sales Machine</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Asap:wght@500;600;700&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link rel="shortcut icon" href="/assets/img/logo2.0.jpg" type="image/x-icon" />

  <!-- LinkedIn Badge Script -->
  <script src="https://platform.linkedin.com/badges/js/profile.js" async defer type="text/javascript"></script>

  <!-- CSS -->
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/reset.css" />
  <link rel="stylesheet" href="/css/keyframes.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/medias.css" />
</head>

<body>
  <!-- Overlay for Mobile Menu -->
  <div class="nav-overlay" id="navOverlay"></div>

  <!-- NAVBAR -->
  <nav class="navbar" id="navbar">
    <div class="container">
      <a href="#home" class="nav-brand">Revenue<span>In</span></a>
      <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#approach">Approach</a></li>
        <li><a href="#testimonials">Testimonials</a></li>
        <li><a href="#contact" class="nav-cta">Let's Talk</a></li>
      </ul>
      <button class="mobile-menu-btn" id="menuBtn" aria-label="Menu">
        &#9776;
      </button>
    </div>
  </nav>

  <!-- MOBILE NAV -->
  <div class="mobile-nav" id="mobileNav">
    <ul>
      <li><a href="#home" class="mobile-link">Home</a></li>
      <li><a href="#about" class="mobile-link">About</a></li>
      <li><a href="#services" class="mobile-link">Services</a></li>
      <li><a href="#approach" class="mobile-link">Approach</a></li>
      <li><a href="#testimonials" class="mobile-link">Testimonials</a></li>
      <li><a href="#contact" class="mobile-link">Contact</a></li>
    </ul>
  </div>

  <main>
    <!-- HERO SECTION -->
    <header class="hero" id="home">
      <div class="container">
        <div class="hero-content reveal-left">
          <span class="hero-tagline">Fractional Sales Leadership</span>
          <h1>Bring your company to the <span class="text-accent text-gradient">next level.</span></h1>
          <p>Deploy high-performing sales teams and scalable revenue strategies to accelerate growth for your startup or
            scale-up.</p>
          <div style="margin-top: 2rem;">
            <a href="#contact" class="btn btn-primary">Book a Consultation</a>
          </div>
        </div>
      </div>
      <!-- Rotating Badge -->
      <div class="hero-badge reveal">
        <svg viewBox="0 0 200 200">
          <path id="circlePath" d="M 100, 100 m -75, 0 a 75,75 0 1,1 150,0 a 75,75 0 1,1 -150,0" fill="none" />
          <text font-size="16" font-weight="600" letter-spacing="3" fill="#D4AF37">
            <textPath href="#circlePath">REVENUEIN • EXCELLENCE • SCALABILITY •</textPath>
          </text>
        </svg>
        <span class="hero-badge-center">Grow<br />Faster</span>
      </div>
    </header>

    <!-- ABOUT SECTION -->
    <section class="section bg-secondary" id="about">
      <div class="container grid-2">
        <div class="about-img-container reveal-left">
          <img src="/assets/img/owner1.jpg" alt="Laetitia Ribier" class="about-img" />
        </div>
        <div class="about-content reveal-right">
          <h2>Empowering CEOs to focus on <span class="text-accent">Vision</span></h2>
          <p>
            CEOs and founders often find themselves overwhelmed wearing different hats, from CMO to CFO. When leaders
            lack time to manage their revenue organization, implementing scalable processes suffers.
          </p>
          <div class="about-highlight">
            "I want to help your company thrive, better, and faster."
          </div>
          <p>
            Relying on a seasoned leader to set up, execute, and scale the business is fundamental to ongoing success.
            With over 13 years of experience, I work hands-on alongside your team to structure the organization and
            accelerate performance.
          </p>
          <a href="#services" class="link-arrow" style="margin-top: 1rem; display: inline-block;">
            Explore my services
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- SERVICES SECTION -->
    <section class="section bg-dark" id="services">
      <div class="container">
        <div class="reveal text-center" style="text-align: center; max-width: 600px; margin: 0 auto 4rem;">
          <h2 class="text-gradient">Core Services</h2>
          <p>Comprehensive revenue operations and leadership to build your sales engine.</p>
        </div>

        <div class="grid-3">
          <!-- Card 1 -->
          <div class="service-card reveal delay-100">
            <div class="service-icon"><img src="/assets/img/icons/IMG-20240326-WA0018_magic.png" alt="Icon" /></div>
            <h3>Hiring & Onboarding</h3>
            <p>Hire the right people and facilitate onboarding for rapid time-to-value and higher performance.</p>
          </div>
          <!-- Card 2 -->
          <div class="service-card reveal delay-200">
            <div class="service-icon"><img src="/assets/img/icons/IMG-20240326-WA0031_magic.png" alt="Icon" /></div>
            <h3>Sales Training</h3>
            <p>Equip your sales team with cutting-edge skills and methodology to strengthen execution.</p>
          </div>
          <!-- Card 3 -->
          <div class="service-card reveal delay-300">
            <div class="service-icon"><img src="/assets/img/icons/IMG-20240326-WA0020_magic.png" alt="Icon" /></div>
            <h3>Performance Management</h3>
            <p>Accurately monitor business metrics and empower your team with strict accountability.</p>
          </div>
          <!-- Card 4 -->
          <div class="service-card reveal delay-100">
            <div class="service-icon"><img src="/assets/img/icons/IMG-20240326-WA0023_magic.png" alt="Icon" /></div>
            <h3>Sales Efficiency</h3>
            <p>Ensure your team executes at the highest level of excellence to convert pipeline into revenue.</p>
          </div>
          <!-- Card 5 -->
          <div class="service-card reveal delay-200">
            <div class="service-icon"><img src="/assets/img/icons/IMG-20240326-WA0033_magic.png" alt="Icon" /></div>
            <h3>Sales Operations</h3>
            <p>Implement the technical and operational environment needed to increase team engagement.</p>
          </div>
          <!-- Card 6 -->
          <div class="service-card reveal delay-300">
            <div class="service-icon"><img src="/assets/img/icons/IMG-20240326-WA0034_magic.png" alt="Icon" /></div>
            <h3>Lead Generation</h3>
            <p>Design effective inbound and outbound strategies to feed your pipeline consistently.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- APPROACH SECTION -->
    <section class="section bg-secondary" id="approach">
      <div class="container grid-2">
        <div class="approach-content reveal-left">
          <h2>Boost your revenue in <span class="text-accent text-gradient">unique ways</span></h2>
          <p>
            I combine deep hands-on operational experience with strategic vision to deliver measurable results. No
            generic playbooks — every engagement is tailored to your team, market, and growth stage.
          </p>
          <div style="margin-top: 2rem;">
            <a href="#contact" class="btn btn-outline">Start the Conversation</a>
          </div>
        </div>

        <div class="approach-grid reveal-right">
          <div class="approach-card">
            <img src="/assets/img/icons/IMG-20240326-WA0024.jpg" alt="Icon" />
            <div>
              <strong>Structured Framework</strong>
              <p>A clear diagnostic process to identify gaps and build precise solutions.</p>
            </div>
          </div>
          <div class="approach-card">
            <img src="/assets/img/icons/IMG-20240326-WA0029.jpg" alt="Icon" />
            <div>
              <strong>Hands-on Execution</strong>
              <p>I don't just advise; I build, run, and iterate on programs directly with your team.</p>
            </div>
          </div>
          <div class="approach-card">
            <img src="/assets/img/icons/IMG-20240326-WA0041.jpg" alt="Icon" />
            <div>
              <strong>Culture of Excellence</strong>
              <p>Embedding ambition and uncompromising accountability into your company DNA.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS SECTION -->
    <section class="section bg-dark" id="testimonials">
      <div class="container">
        <h2 class="text-center reveal" style="text-align: center; margin-bottom: 4rem;">What My Clients Say</h2>

        <div class="testimonials-slider reveal delay-200">
          <div class="slider-track" id="sliderTrack">
            <% if (typeof testimonials !=='undefined' && testimonials.length> 0) { %>
              <% testimonials.forEach(t=> { %>
                <div class="slide">
                  <div class="testimonial-card">
                    <div class="quote-icon">"</div>
                    <p class="testimonial-text">"<%= t.content %>"</p>
                    <div class="testimonial-author">
                      <h4>
                        <%= t.authorName %>
                      </h4>
                      <em>
                        <%= t.authorTitle %>
                      </em>
                    </div>
                  </div>
                </div>
                <% }) %>
                  <% } else { %>
                    <div class="slide">
                      <div class="testimonial-card">
                        <div class="quote-icon">"</div>
                        <p class="testimonial-text">"Laetitia worked for us as an Operating Partner in order to help
                          increase our Sales performance... The results speak for themselves. Merci Laetitia!"</p>
                        <div class="testimonial-author">
                          <h4>Paul B. &mdash; CEO Modjo</h4>
                          <em>Mission performed in partnership with Atscale</em>
                        </div>
                      </div>
                    </div>
                    <% } %>
          </div>

          <!-- Nav Arrows -->
          <button class="slider-btn slider-prev" id="sliderPrev" aria-label="Previous">&#8592;</button>
          <button class="slider-btn slider-next" id="sliderNext" aria-label="Next">&#8594;</button>

          <!-- Dots -->
          <div class="slider-dots" id="sliderDots"></div>
        </div>
      </div>
    </section>

    <!-- CONTACT & FOOTER -->
    <section class="section footer-section" id="contact">
      <div class="container grid-2">

        <div class="contact-info reveal-left">
          <h2>Ready to Scale? <span class="text-accent">Let's talk.</span></h2>
          <p>Reach out to discuss your revenue goals and discover how fractional leadership can act as a catalyst for
            your organization.</p>

          <div style="margin: 3rem 0;">
            <!-- LinkedIn Profile Badge -->
            <div class="badge-base LI-profile-badge" data-locale="fr_FR" data-size="large" data-theme="dark"
              data-type="HORIZONTAL" data-vanity="laetitiaribier" data-version="v1">
              <a class="badge-base__link LI-simple-link"
                href="https://fr.linkedin.com/in/laetitiaribier?trk=profile-badge" target="_blank"
                rel="noopener noreferrer">Laetitia Ribier on LinkedIn</a>
            </div>
          </div>
        </div>

        <div class="contact-form reveal-right"
          style="background: rgba(255,255,255,0.02); padding: 3rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05);">
          <form id="mainContactForm" method="POST" action="/contact">
            <div class="form-group">
              <input type="text" name="name" id="name" class="form-control" placeholder="Your Name" required />
            </div>
            <div class="form-group">
              <input type="email" name="email" id="email" class="form-control" placeholder="Your Email" required />
            </div>
            <div class="form-group">
              <textarea name="message" id="message" class="form-control" placeholder="How can I help you?"
                required></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Send Message</button>
          </form>
        </div>
      </div>

      <div class="container footer-bottom">
        <p>&copy; 2024 RevenueIn. Powered by Micka&euml;l Ribier.</p>
        <a href="#home" class="link-arrow" style="font-size: 0.9rem;">Back to Top &uarr;</a>
      </div>
    </section>
  </main>

  <!-- Contact Form Success Modal -->
  <div id="contactModal"
    style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:9999; align-items:center; justify-content:center; backdrop-filter:blur(4px);">
    <div
      style="background:#1C2541; border:1px solid rgba(212,175,55,0.3); border-radius:20px; padding:3rem 2.5rem; max-width:480px; width:90%; text-align:center; box-shadow: 0 25px 60px rgba(0,0,0,0.5); animation: fadeIn 0.4s ease;">
      <div
        style="width:70px; height:70px; background:rgba(212,175,55,0.1); border-radius:50%; margin:0 auto 1.5rem; display:flex; align-items:center; justify-content:center;">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
          <polyline points="22 4 12 14.01 9 11.01" />
        </svg>
      </div>
      <h3 style="color:#D4AF37; font-family:'Asap',sans-serif; font-size:1.6rem; margin-bottom:0.75rem;">Message Sent!
      </h3>
      <p style="color:rgba(255,255,255,0.7); line-height:1.7; margin-bottom:2rem;">Thank you for reaching out. I'll get
        back to you as soon as possible.</p>
      <button onclick="document.getElementById('contactModal').style.display='none'"
        style="background:#D4AF37; color:#0A1128; border:none; padding:0.8rem 2.5rem; border-radius:50px; font-weight:600; cursor:pointer; font-size:1rem; transition:opacity 0.2s;"
        onmouseover="this.style.opacity=0.85" onmouseout="this.style.opacity=1">Close</button>
    </div>
  </div>

  <!-- JS -->
  <script type="module" src="/js/index.js"></script>
</body>

</html>