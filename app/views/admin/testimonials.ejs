<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Testimonials - RevenueIn</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-gray-50 flex h-screen text-gray-800">

    <!-- Sidebar -->
    <aside class="w-64 bg-slate-900 text-white flex flex-col">
        <div class="p-6">
            <h2 class="text-2xl font-bold text-yellow-500">Revenue<span class="text-white">In</span></h2>
            <p class="text-xs text-gray-400 mt-1">Admin Portal</p>
        </div>

        <nav class="flex-1 px-4 space-y-2 mt-4">
            <a href="/admin"
                class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-colors hover:bg-slate-700 text-gray-300">
                <i class="fas fa-inbox w-5"></i> Messages
            </a>
            <a href="/admin/testimonials"
                class="flex items-center gap-3 px-4 py-3 bg-slate-800 rounded-lg text-sm font-medium transition-colors hover:bg-slate-700">
                <i class="fas fa-quote-left w-5"></i> Testimonials
            </a>
        </nav>

        <div class="p-4 border-t border-slate-700">
            <a href="/logout"
                class="block w-full text-center px-4 py-2 bg-red-500/10 text-red-500 rounded hover:bg-red-500/20 text-sm transition-colors">
                Logout
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto bg-gray-50 flex flex-col">
        <header class="bg-white border-b border-gray-200 px-8 py-5 flex justify-between items-center">
            <h1 class="text-2xl font-semibold text-gray-800">Manage Testimonials</h1>
            <button onclick="document.getElementById('addModal').classList.remove('hidden')"
                class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded shadow-sm text-sm font-medium transition-colors">
                + Add Testimonial
            </button>
        </header>

        <div class="p-8 flex-1">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if (testimonials && testimonials.length> 0) { %>
                    <% testimonials.forEach(t=> { %>
                        <div
                            class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 flex flex-col relative <%= !t.isActive ? 'opacity-50' : '' %>">

                            <!-- Actions -->
                            <div class="absolute top-4 right-4 flex gap-2">
                                <form action="/admin/testimonials/<%= t.id %>/toggle" method="POST">
                                    <button type="submit" class="text-gray-400 hover:text-blue-600 transition"
                                        title="Toggle visibility">
                                        <i class="fas <%= t.isActive ? 'fa-eye' : 'fa-eye-slash' %>"></i>
                                    </button>
                                </form>
                                <form action="/admin/testimonials/<%= t.id %>/delete" method="POST"
                                    onsubmit="return confirm('Are you sure you want to delete this?')">
                                    <button type="submit" class="text-gray-400 hover:text-red-600 transition"
                                        title="Delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>

                            <div class="text-3xl text-yellow-500/20 mb-2 font-serif">"</div>
                            <p class="text-sm text-gray-600 italic flex-1 mb-6">
                                <%= t.content %>
                            </p>

                            <div class="border-t border-gray-100 pt-4 mt-auto">
                                <h4 class="font-medium text-gray-900 text-sm">
                                    <%= t.authorName %>
                                </h4>
                                <p class="text-xs text-gray-500 mt-0.5">
                                    <%= t.authorTitle %>
                                </p>
                            </div>
                        </div>
                        <% }) %>
                            <% } else { %>
                                <div
                                    class="col-span-full p-12 bg-white rounded-xl border border-gray-200 text-center text-gray-500">
                                    <p>No testimonials added yet.</p>
                                </div>
                                <% } %>
            </div>
        </div>
    </main>

    <!-- Add Modal -->
    <div id="addModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center backdrop-blur-sm">
        <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                <h3 class="font-semibold text-lg">Add New Testimonial</h3>
                <button onclick="document.getElementById('addModal').classList.add('hidden')"
                    class="text-gray-400 hover:text-gray-600">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <form action="/admin/testimonials" method="POST" class="p-6">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Author Name *</label>
                        <input type="text" name="authorName" required
                            class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Role / Company (e.g. CEO,
                            Modjo)</label>
                        <input type="text" name="authorTitle"
                            class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Testimonial Content *</label>
                        <textarea name="content" required rows="4"
                            class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500"></textarea>
                    </div>
                    <div class="flex items-center gap-2 mt-2">
                        <input type="checkbox" name="isActive" id="isActive" checked
                            class="rounded text-blue-600 focus:ring-blue-500">
                        <label for="isActive" class="text-sm text-gray-700">Visible on public site</label>
                    </div>
                </div>
                <div class="mt-6 pt-4 border-t border-gray-100 flex justify-end gap-3">
                    <button type="button" onclick="document.getElementById('addModal').classList.add('hidden')"
                        class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded transition-colors">Cancel</button>
                    <button type="submit"
                        class="px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded transition-colors">Save
                        Testimonial</button>
                </div>
            </form>
        </div>
    </div>

</body>

</html>