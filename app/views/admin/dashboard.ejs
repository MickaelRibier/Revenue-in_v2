<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - RevenueIn</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>

<body class="bg-gray-50 flex h-screen text-gray-800">

    <!-- Sidebar -->
    <aside class="w-64 bg-slate-900 text-white flex flex-col shrink-0">
        <div class="p-6">
            <h2 class="text-2xl font-bold text-yellow-500">Revenue<span class="text-white">In</span></h2>
            <p class="text-xs text-gray-400 mt-1">Admin Portal</p>
        </div>
        <nav class="flex-1 px-4 space-y-2 mt-4">
            <a href="/admin"
                class="flex items-center gap-3 px-4 py-3 bg-slate-800 rounded-lg text-sm font-medium hover:bg-slate-700">
                <i class="fas fa-inbox w-5"></i> Messages
            </a>
            <a href="/admin/testimonials"
                class="flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium hover:bg-slate-700 text-gray-300">
                <i class="fas fa-quote-left w-5"></i> Testimonials
            </a>
        </nav>
        <div class="p-4 border-t border-slate-700">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-8 h-8 rounded-full bg-slate-600 flex items-center justify-center">
                    <i class="fas fa-user text-sm"></i>
                </div>
                <p class="text-sm font-medium truncate">
                    <%= user ? user.name : 'Admin' %>
                </p>
            </div>
            <a href="/logout"
                class="block w-full text-center px-4 py-2 bg-red-500/10 text-red-500 rounded hover:bg-red-500/20 text-sm">Logout</a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto">
        <header class="bg-white border-b border-gray-200 px-8 py-5">
            <h1 class="text-2xl font-semibold text-gray-800">Contact Messages</h1>
            <p class="text-sm text-gray-400 mt-1">Click on a row to read the full message</p>
        </header>

        <div class="p-8">
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <% if (messages && messages.length> 0) { %>
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-200 text-sm text-gray-500">
                                <th class="py-3 px-6 font-medium">Name</th>
                                <th class="py-3 px-6 font-medium">Email</th>
                                <th class="py-3 px-6 font-medium">Preview</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm">
                            <% messages.forEach(function(msg) { %>
                                <tr class="msg-row border-b border-gray-100 hover:bg-yellow-50/50 cursor-pointer transition-colors"
                                    data-name="<%- msg.name %>" data-email="<%- msg.email %>"
                                    data-message="<%- msg.message %>">
                                    <td class="py-4 px-6 font-medium text-gray-800"><%- msg.name %></td>
                                    <td class="py-4 px-6 text-blue-600"><%- msg.email %></td>
                                    <td class="py-4 px-6 text-gray-500 max-w-xs truncate">
                                        <%- msg.message.substring(0, 80) %>
                                            <%= msg.message.length> 80 ? '…' : '' %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                    <% } else { %>
                        <div class="p-12 text-center text-gray-500">
                            <i class="fas fa-inbox text-4xl mb-3 text-gray-300 block"></i>
                            <p>No messages received yet.</p>
                        </div>
                        <% } %>
            </div>
        </div>
    </main>

    <!-- Message Detail Modal -->
    <div id="msgModal"
        class="hidden fixed inset-0 z-50 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg">
            <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-start">
                <div>
                    <h3 id="modalName" class="font-semibold text-lg text-gray-900"></h3>
                    <a id="modalEmail" href="#" class="text-sm text-blue-600 hover:underline"></a>
                </div>
                <button id="closeModal"
                    class="text-gray-400 hover:text-gray-600 text-2xl leading-none mt-0.5">&times;</button>
            </div>
            <div class="p-6">
                <p id="modalMessage" class="text-gray-700 leading-relaxed whitespace-pre-wrap text-sm"></p>
            </div>
            <div class="px-6 pb-5 flex gap-3 justify-end">
                <a id="modalReply" href="#"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                    <i class="fas fa-reply mr-1.5"></i> Reply by Email
                </a>
                <button id="closeModal2"
                    class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors">Close</button>
            </div>
        </div>
    </div>

    <script>
        const modal = document.getElementById('msgModal');

        document.querySelectorAll('.msg-row').forEach(function (row) {
            row.addEventListener('click', function () {
                var name = row.getAttribute('data-name');
                var email = row.getAttribute('data-email');
                var message = row.getAttribute('data-message');

                document.getElementById('modalName').textContent = name;
                var emailEl = document.getElementById('modalEmail');
                emailEl.textContent = email;
                emailEl.href = 'mailto:' + email;
                document.getElementById('modalMessage').textContent = message;
                document.getElementById('modalReply').href = 'mailto:' + email + '?subject=Re: Your message on RevenueIn';

                modal.classList.remove('hidden');
            });
        });

        function closeModal() {
            modal.classList.add('hidden');
        }

        document.getElementById('closeModal').addEventListener('click', closeModal);
        document.getElementById('closeModal2').addEventListener('click', closeModal);
        modal.addEventListener('click', function (e) {
            if (e.target === modal) closeModal();
        });
    </script>
</body>

</html>