<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - RevenueIn</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-950 min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md px-6">
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-white">Revenue<span class="text-yellow-500">In</span></h1>
            <p class="text-gray-400 mt-2 text-sm">Admin Portal</p>
        </div>

        <% if (locals.error) { %>
            <div class="bg-red-500/10 text-red-400 border border-red-500/20 rounded-lg p-4 mb-6 text-sm text-center">
                <%= error %>
            </div>
            <% } %>

                <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow-xl">
                    <% if (locals.googleEnabled) { %>
                        <!-- Google OAuth Button -->
                        <a href="/auth/google"
                            class="flex items-center justify-center gap-3 w-full bg-white hover:bg-gray-100 text-gray-800 font-semibold py-3 px-5 rounded-xl transition-colors mb-6">
                            <svg viewBox="0 0 24 24" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
                                <path
                                    d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                                    fill="#4285F4" />
                                <path
                                    d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                                    fill="#34A853" />
                                <path
                                    d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                                    fill="#FBBC05" />
                                <path
                                    d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                                    fill="#EA4335" />
                            </svg>
                            Continue with Google
                        </a>
                        <div class="flex items-center gap-3 mb-6">
                            <div class="h-px flex-1 bg-slate-700"></div>
                            <span class="text-gray-500 text-xs">or use password</span>
                            <div class="h-px flex-1 bg-slate-700"></div>
                        </div>
                        <% } %>

                            <!-- Local Password Login -->
                            <form action="/auth/local" method="POST" class="space-y-4">
                                <div>
                                    <label class="block text-sm text-gray-400 mb-1.5">Admin Password</label>
                                    <input type="password" name="password" required placeholder="Enter admin password"
                                        class="w-full bg-slate-800 border border-slate-700 text-white rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-yellow-500/30 focus:border-yellow-500 placeholder-slate-500 text-sm">
                                </div>
                                <button type="submit"
                                    class="w-full bg-yellow-500 hover:bg-yellow-400 text-slate-950 font-semibold py-3 rounded-xl transition-colors text-sm">
                                    Sign in
                                </button>
                            </form>
                </div>

                <p class="text-center text-gray-600 text-xs mt-6">
                    <a href="/" class="hover:text-gray-400 transition-colors">← Back to site</a>
                </p>
    </div>
</body>

</html>